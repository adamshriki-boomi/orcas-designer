# Browser-side env vars (must be NEXT_PUBLIC_* — exposed in the client bundle).
# Copy this file to .env.local and fill in real values.

# Supabase project — find both in Supabase dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Figma OAuth client_id — public per Figma's OAuth docs, safe to ship in the
# browser bundle. Find at figma.com/developers/apps → your app → OAuth credentials.
# The matching FIGMA_CLIENT_SECRET (private) lives in Supabase edge function
# secrets, NOT here.
NEXT_PUBLIC_FIGMA_CLIENT_ID=
